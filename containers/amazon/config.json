{
  "retailer_id": "amazon",
  "display_name": "Amazon",
  "base_url": "https://www.amazon.com",
  "script_version": "0.1.0",
  "search_url_template": "https://www.amazon.com/s?k=",
  "selectors": {
    "anchor": "[data-component-type=\"s-search-result\"]",
    "title": "[data-cy=\"title-recipe\"] span",
    "title_fallback_1": "h2 a span",
    "title_fallback_2": "img[alt]",
    "price": ".a-price:not([data-a-strike]) .a-offscreen",
    "original_price": ".a-price[data-a-strike] .a-offscreen",
    "image": "img.s-image",
    "url": "a[href*=\"/dp/\"]",
    "rating": ".a-icon-alt"
  },
  "rate_limit": {
    "requests_per_minute": 8,
    "concurrent": 1,
    "backoff_seconds": [5, 15, 60]
  },
  "anti_detection": {
    "warm_up": true,
    "warm_up_url": "https://www.amazon.com",
    "wait_strategy": "networkidle",
    "jitter_min_ms": 1000,
    "jitter_max_ms": 3000,
    "scroll_passes": 5
  },
  "health": {
    "consecutive_failures": 0,
    "max_failures_before_alert": 3,
    "status": "healthy"
  }
}
