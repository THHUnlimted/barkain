{
  "retailer_id": "lowes",
  "display_name": "Lowe's",
  "base_url": "https://www.lowes.com",
  "script_version": "0.1.0",
  "search_url_template": "https://www.lowes.com/search?searchTerm=",
  "anchor_status": "needs_validation",
  "anchor_note": "Selectors are best-guess. Lowe's likely uses data-testid attributes on product cards. Needs live testing to confirm correct anchor selector.",
  "selectors": {
    "anchor": "[data-testid=\"product-card\"]",
    "anchor_fallback_1": ".plp-card",
    "anchor_fallback_2": "[data-productid]",
    "anchor_fallback_3": "a[href*=\"/pd/\"]",
    "title": "[data-testid=\"product-title\"]",
    "price": "[data-testid=\"product-price\"]",
    "image": "img[src*=\"lowes\"]",
    "url": "a[href*=\"/pd/\"]"
  },
  "rate_limit": {
    "requests_per_minute": 6,
    "concurrent": 1,
    "backoff_seconds": [5, 15, 60]
  },
  "anti_detection": {
    "warm_up": true,
    "warm_up_url": "https://www.lowes.com",
    "wait_strategy": "networkidle",
    "jitter_min_ms": 1000,
    "jitter_max_ms": 3000,
    "scroll_passes": 5
  },
  "health": {
    "consecutive_failures": 0,
    "max_failures_before_alert": 3,
    "status": "healthy"
  }
}
