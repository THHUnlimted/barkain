# Barkain — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app:localdev@localhost:5432/barkain
TEST_DATABASE_URL=postgresql+asyncpg://app:test@localhost:5433/barkain_test

# ── Cache ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Clerk) ─────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ── Retail Data APIs (Phase 4 production optimization) ─
BEST_BUY_API_KEY=xxxxx
EBAY_CLIENT_ID=xxxxx
EBAY_CLIENT_SECRET=xxxxx
KEEPA_API_KEY=xxxxx

# ── UPC Resolution (Phase 1) ──────────────────────────
GEMINI_API_KEY=xxxxx
UPCITEMDB_API_KEY=xxxxx

# ── AI Models (Phase 3: recommendations, fallback) ───
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# ── Affiliate (Phase 2 — leave blank until approved) ─
AMAZON_ASSOCIATE_TAG=
EBAY_CAMPAIGN_ID=
CJ_WEBSITE_ID=

# ── Environment ──────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_GENERAL=60
RATE_LIMIT_WRITE=30
RATE_LIMIT_AI=10

# ── Containers (agent-browser scraper infrastructure) ─
CONTAINER_URL_PATTERN=http://localhost:808{port}
CONTAINER_TIMEOUT_SECONDS=30
CONTAINER_RETRY_COUNT=1

# ── Walmart Adapter Routing ───────────────────────────
# Which path handles walmart scrapes. Other retailers always use the
# container dispatch. Valid values:
#   container    — legacy browser container (broken for walmart from any cloud)
#   firecrawl    — demo path via Firecrawl managed API (set FIRECRAWL_API_KEY)
#   decodo_http  — production path via Decodo residential proxy (set DECODO_*)
# See docs/SCRAPING_AGENT_ARCHITECTURE.md Appendices A–C for the decision trail.
WALMART_ADAPTER=firecrawl

# ── Firecrawl (walmart demo path) ─────────────────────
# Get your API key from https://firecrawl.dev/app/api-keys
# Only required when WALMART_ADAPTER=firecrawl.
FIRECRAWL_API_KEY=fc-xxxxx

# ── Decodo residential proxy (walmart production path) ─
# Sign up at https://decodo.com; credentials are in the dashboard under
# Residential Proxies → Authentication. Only required when
# WALMART_ADAPTER=decodo_http. The username will be automatically
# prefixed with `user-` and suffixed with `-country-us` so you can set
# DECODO_PROXY_USER to the bare username from the dashboard.
DECODO_PROXY_USER=
DECODO_PROXY_PASS=
DECODO_PROXY_HOST=gate.decodo.com:7000
