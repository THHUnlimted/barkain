# Barkain — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
#
# Only genuine overrides live here — values that MUST differ from the
# defaults in backend/app/config.py.  Duplicating defaults creates drift
# traps (see SP-5 post-mortem).

# ── Auth (Clerk) ── required for all non-demo usage ─
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ── UPC Resolution ── required for product scanning ─
GEMINI_API_KEY=xxxxx
# Optional: UPCitemdb paid tier key. Leave blank to use free trial (100/day).
UPCITEMDB_API_KEY=

# ── AI / Watchdog ── required for self-healing + recommendations ─
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Optional: Slack incoming webhook for Watchdog escalation notifications.
# Leave empty to only log escalations to stdout.
# WATCHDOG_SLACK_WEBHOOK=https://hooks.slack.com/services/xxxxx

# ── Walmart Adapter Routing ──────────────────────────
# Which path handles walmart scrapes. Other retailers always use the
# container dispatch. Valid values:
#   decodo_http  — DEFAULT. Production path via Decodo residential proxy
#                  (set DECODO_PROXY_USER / DECODO_PROXY_PASS). ~2.8s per
#                  scrape, ~100% success at current pool health.
#   firecrawl    — legacy demo path via Firecrawl managed API. Firecrawl's
#                  upstream is currently 100% blocked by PerimeterX on
#                  Walmart — kept selectable for future recovery.
#   container    — legacy browser container, broken from any cloud IP.
# See docs/SCRAPING_AGENT_ARCHITECTURE.md Appendices A–C.
WALMART_ADAPTER=decodo_http

# ── Firecrawl (walmart demo path) ────────────────────
# Get your API key from https://firecrawl.dev/app/api-keys
# Only required when WALMART_ADAPTER=firecrawl.
FIRECRAWL_API_KEY=fc-xxxxx

# ── Decodo residential proxy (walmart production path) ─
# Sign up at https://decodo.com; credentials are in the dashboard under
# Residential Proxies → Authentication. Only required when
# WALMART_ADAPTER=decodo_http. The username will be automatically
# prefixed with `user-` and suffixed with `-country-us`.
DECODO_PROXY_USER=
DECODO_PROXY_PASS=

# ── Container Timeout ────────────────────────────────
# Override default 30s. Demo needs 180s for Best Buy warmup+scroll on
# EC2 t3.xlarge. Adjust down once warm-container pool is in place.
CONTAINER_TIMEOUT_SECONDS=180

# ── Database ─────────────────────────────────────────
# Defaults to local Docker (see docker-compose.yml). Uncomment and edit only
# when pointing to a different instance (staging RDS, a second local db, etc.).
# DATABASE_URL=postgresql+asyncpg://app:localdev@localhost:5432/barkain

# ── Billing / RevenueCat (Step 2f) ───────────────────
# Shared bearer token used to validate RevenueCat webhook requests against
# POST /api/v1/billing/webhook. Configure the same value in the RevenueCat
# dashboard under Project Settings → Integrations → Webhooks → Authorization.
# Required for the billing webhook to accept events (misconfig → 401).
REVENUECAT_WEBHOOK_SECRET=

# ── Affiliate Programs (Step 2g) ─────────────────────
# Amazon Associates store ID — live. Appended as ?tag=<id> to product URLs.
AMAZON_ASSOCIATE_TAG=barkain-20
# eBay Partner Network campaign ID — live. Used to build rover.ebay.com redirects.
EBAY_CAMPAIGN_ID=5339148665
# Walmart Impact Radius affiliate ID — placeholder, pending approval. Leave
# empty to pass Walmart product URLs through untagged.
# WALMART_AFFILIATE_ID=
# Shared bearer token for POST /api/v1/affiliate/conversion placeholder.
# Leave empty to accept any request (permissive placeholder mode).
AFFILIATE_WEBHOOK_SECRET=

# ── eBay Browse API + Marketplace Account Deletion webhook (Step 3b) ─
# Developer portal "Production Keyset". When both App ID + Cert ID are
# populated the ebay_new / ebay_used retailer legs route through the
# Browse API instead of the browser-container scrapers. App tokens
# auto-refresh (client_credentials grant, 2 hr TTL, cached in-process).
EBAY_APP_ID=
EBAY_CERT_ID=
# EXPERIMENT — Tier 2 search swap. SEARCH_TIER2_USE_EBAY swaps the second
# leg of the M1 Tier 2 cascade (parallel with Best Buy) from UPCitemdb to
# the eBay Browse API keyword search. USE_GTIN surfaces eBay's `gtin` as
# the row's primary_upc when present (rare on item_summary even with
# fieldgroups=EXTENDED, but harmless to leave on). SKIP_UPC forces eBay
# rows to omit primary_upc so iOS goes straight to /resolve-from-search.
# All three default off — flip to true to A/B without code changes.
SEARCH_TIER2_USE_EBAY=false
SEARCH_TIER2_EBAY_USE_GTIN=false
SEARCH_TIER2_EBAY_SKIP_UPC=false
# EXPERIMENT — drop "box only", "for parts", "charger only" style listings
# from the M2 ebay_browse_api price stream. Especially noisy on used
# categories (laptops, phones). Default off.
M2_EBAY_DROP_PARTIAL_LISTINGS=false
# GDPR — required for Browse API production access. The token is an
# opaque 32-80 char string you generate (`openssl rand -hex 32`) and
# paste into the eBay portal + here. Endpoint is the fully-qualified
# public HTTPS URL eBay calls. The two MUST match exactly in both
# places or the SHA-256 challenge hash won't line up.
EBAY_VERIFICATION_TOKEN=
EBAY_ACCOUNT_DELETION_ENDPOINT=

# ── Best Buy Products API (Step 3c-bestbuy) ──────────
# Developer portal key (developer.bestbuy.com → My Account → Keys).
# When set, the best_buy retailer leg routes through the Products API
# (~150 ms per call) instead of the browser-container scraper
# (~80–90 s). Missing key → container fallback, same pattern as eBay.
# Free tier: 5 calls/sec, 50k/day.
BESTBUY_API_KEY=

# ── Background Workers (Step 2h) ─────────────────────
# LocalStack SQS endpoint for local dev. Leave empty in production so
# boto3 resolves real AWS SQS via the default credential chain (IAM
# role, ~/.aws/credentials, etc.).
SQS_ENDPOINT_URL=http://localhost:4566
SQS_REGION=us-east-1
# LocalStack accepts any AWS credentials; "test"/"test" is the convention.
# boto3 reads AWS_* directly from the environment, not from config.py.
# In prod, set these from IAM or leave empty to use the default chain.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Worker cadence — seeded with prod defaults; tune via env if needed.
PRICE_INGESTION_STALE_HOURS=6
DISCOUNT_VERIFICATION_STALE_DAYS=7
DISCOUNT_VERIFICATION_FAILURE_THRESHOLD=3

# ── Demo Mode ────────────────────────────────────────
# Uncomment to bypass Clerk auth for local testing. NEVER use in production.
# Renamed in Step 2i-b — was BARKAIN_DEMO_MODE; pydantic-settings now reads
# this directly into settings.DEMO_MODE.
# DEMO_MODE=1
