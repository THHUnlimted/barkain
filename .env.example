# Barkain — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
#
# Only genuine overrides live here — values that MUST differ from the
# defaults in backend/app/config.py.  Duplicating defaults creates drift
# traps (see SP-5 post-mortem).

# ── Auth (Clerk) ── required for all non-demo usage ─
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ── UPC Resolution ── required for product scanning ─
GEMINI_API_KEY=xxxxx
# Optional: UPCitemdb paid tier key. Leave blank to use free trial (100/day).
UPCITEMDB_API_KEY=

# ── AI / Watchdog ── required for self-healing + recommendations ─
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Walmart Adapter Routing ──────────────────────────
# Which path handles walmart scrapes. Other retailers always use the
# container dispatch. Valid values:
#   container    — legacy browser container (broken from any cloud IP)
#   firecrawl    — demo path via Firecrawl managed API (set FIRECRAWL_API_KEY)
#   decodo_http  — production path via Decodo residential proxy (set DECODO_*)
# See docs/SCRAPING_AGENT_ARCHITECTURE.md Appendices A–C.
WALMART_ADAPTER=firecrawl

# ── Firecrawl (walmart demo path) ────────────────────
# Get your API key from https://firecrawl.dev/app/api-keys
# Only required when WALMART_ADAPTER=firecrawl.
FIRECRAWL_API_KEY=fc-xxxxx

# ── Decodo residential proxy (walmart production path) ─
# Sign up at https://decodo.com; credentials are in the dashboard under
# Residential Proxies → Authentication. Only required when
# WALMART_ADAPTER=decodo_http. The username will be automatically
# prefixed with `user-` and suffixed with `-country-us`.
DECODO_PROXY_USER=
DECODO_PROXY_PASS=

# ── Container Timeout ────────────────────────────────
# Override default 30s. Demo needs 180s for Best Buy warmup+scroll on
# EC2 t3.xlarge. Adjust down once warm-container pool is in place.
CONTAINER_TIMEOUT_SECONDS=180

# ── Demo Mode ────────────────────────────────────────
# Uncomment to bypass Clerk auth for local testing. NEVER use in production.
# BARKAIN_DEMO_MODE=1
